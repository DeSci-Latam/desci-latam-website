---
import { cn } from "@/lib/utils";
import type { InfoLdg } from "@/types";

interface Props {
  reverse?: boolean;
  data: InfoLdg;
}

const { reverse, data } = Astro.props;
---

<div class="py-16 sm:py-20 px-4 sm:px-6 lg:px-8" style="background: transparent; color: #f0eaff;">
  <div class="mx-auto grid max-w-7xl gap-10 sm:gap-16 lg:grid-cols-2 lg:items-center">

    <!-- Text column -->
    <div class={cn(reverse ? "lg:order-2" : "lg:order-1")}>
      <h2 class="font-heading text-3xl font-bold md:text-4xl" style="color: #f0eaff;">
        {data.title}
      </h2>
      <p class="mt-4 text-base leading-relaxed" style="color: #a89dc8;">
        {data.description}
      </p>
      <dl class="mt-6 space-y-4 leading-7">
        {data.list.map((item) => (
          <div class="flex items-start gap-3">
            <div class="mt-1 w-5 h-5 rounded-full flex-shrink-0 flex items-center justify-center" style="background: rgba(155,90,255,0.15);">
              <div class="w-2 h-2 rounded-full" style="background: #9b5aff;"></div>
            </div>
            <div>
              <dt class="font-semibold text-sm" style="color: #f0eaff;">{item.title}</dt>
              <dd class="text-sm mt-0.5" style="color: #a89dc8;">{item.description}</dd>
            </div>
          </div>
        ))}
      </dl>
    </div>

    <!-- Image column -->
    <div class={cn(
      "rounded-2xl overflow-hidden",
      reverse ? "lg:order-1" : "lg:order-2"
    )} style="border: 1px solid rgba(99,66,210,0.25);">
      <div class="relative aspect-video">
        <img
          class="w-full h-full object-cover object-center"
          src={data.image}
          alt={data.title}
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

  </div>
</div>
