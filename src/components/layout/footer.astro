---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { LOCALES, useTranslations, type Lang } from "@/i18n";
import { ThemeToggle } from "@/components/theme-toggle";
import { siteConfig } from "@/config/site";
import { cn } from "@/lib/utils";
import { Icon } from "astro-icon/components";
import { LogoFooter } from "../../assets/logos/LogoFooter";   
type Props = {
  className?: string;
};




const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);



const { className } = Astro.props;
---


<footer class={cn("border-t border-border1 dark:border-gray2", className)}>
  {/* Sección principal */}
  <div class="container grid grid-cols-1 gap-8 py-8 sm:grid-cols-2 md:grid-cols-5 max-w-[1280px]">
    {/* Primera columna con logo */}
    <div class="md:col-span-1">

<div class="flex pb-2">
      <a href={getRelativeLocaleUrl(locale, "/")}>
        <LogoFooter />
      </a></div>


      <p class="text-sm text-gray-600 dark:text-gray-300 mb-4">
        {t({
          es: "El hub de Science & Technology de LATAM. Conectando investigación con financiamiento y colaboración global.",
          en: "The S&T Hub of LATAM. Connecting research with funding and global collaboration.",
          pt: "O hub de Science & Technology da LATAM. Conectando pesquisa com financiamento e colaboração global."
        })}
      </p>
      <div class="flex space-x-4">
        <a
          href={siteConfig.links.twitter}
          target="_blank"
          rel="noreferrer"
          aria-label="X / Twitter"
          class="text-gray-400 hover:text-maincolor transition-colors"
        >
          <Icon name="twitter" class="size-5" />
        </a>
        <a
          href={siteConfig.links.github}
          target="_blank"
          rel="noreferrer"
          aria-label="GitHub"
          class="text-gray-400 hover:text-maincolor transition-colors"
        >
          <Icon name="github" class="size-5" />
        </a>
        <a
          href="https://t.me/descilatam"
          target="_blank"
          rel="noreferrer"
          aria-label="Telegram"
          class="text-gray-400 hover:text-maincolor transition-colors"
        >
          <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.96 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
        </a>
      </div>
    </div>

    {/* Columna Explorar */}
    <div>
      <span class="text-sm font-medium text-foreground uppercase tracking-wider">
        {t({
          es: "Explorar",
          en: "Explore",
          pt: "Explorar"
        })}
      </span>
      <ul class="mt-4 list-inside space-y-3">
        <li>
          <a
            href={getRelativeLocaleUrl(locale, "/learn/what-is-desci")}
            class="text-sm text-gray-600 dark:text-gray-300 hover:text-maincolor dark:hover:text-white transition-colors"
          >
            {t({
              es: "¿Qué es DeSci?",
              en: "What is DeSci?",
              pt: "O que é DeSci?"
            })}
          </a>
        </li>
        <li>
          <a
            href={getRelativeLocaleUrl(locale, "/blog")}
            class="text-sm text-gray-600 dark:text-gray-300 hover:text-maincolor dark:hover:text-white transition-colors"
          >
            Blog
          </a>
        </li>
        <li>
          <a
            href={getRelativeLocaleUrl(locale, "/resources")}
            class="text-sm text-gray-600 dark:text-gray-300 hover:text-maincolor dark:hover:text-white transition-colors"
          >
            {t({
              es: "Recursos",
              en: "Resources",
              pt: "Recursos"
            })}
          </a>
        </li>
      </ul>
    </div>

    {/* Columna Comunidad */}
    <div>
      <span class="text-sm font-medium text-foreground uppercase tracking-wider">
        {t({
          es: "Comunidad",
          en: "Community",
          pt: "Comunidade"
        })}
      </span>
      <ul class="mt-4 mb-4 list-inside space-y-3">
        <li>
          <a
            href={getRelativeLocaleUrl(locale, "/community/events")}
            class="text-sm text-gray-600 dark:text-gray-300 hover:text-maincolor dark:hover:text-white transition-colors"
          >
            {t({
              es: "Eventos",
              en: "Events",
              pt: "Eventos"
            })}
          </a>
        </li>
        <li>
          <a
            href={getRelativeLocaleUrl(locale, "/community/global-communities")}
            class="text-sm text-gray-600 dark:text-gray-300 hover:text-maincolor dark:hover:text-white transition-colors"
          >
            {t({
              es: "Comunidades Globales",
              en: "Global Communities",
              pt: "Comunidades Globais"
            })}
          </a>
        </li>
      </ul>

<span class="text-sm font-medium mt-4 text-foreground uppercase tracking-wider">
        {t({
          es: "Recursos",
          en: "Resources",
          pt: "Recursos"
        })}
      </span>
      <ul class="mt-4 list-inside space-y-3">
        <li>
          <a
            href={getRelativeLocaleUrl(locale, "/resources/funding")}
            class="text-sm text-gray-600 dark:text-gray-300 hover:text-maincolor dark:hover:text-white transition-colors"
          >
            {t({
              es: "Financiamiento",
              en: "Funding",
              pt: "Financiamento"
            })}
          </a>
        </li>
        <li>
          <a
            href={getRelativeLocaleUrl(locale, "/resources/toolkit")}
            class="text-sm text-gray-600 dark:text-gray-300 hover:text-maincolor dark:hover:text-white transition-colors"
          >
            {t({
              es: "Kit de Herramientas",
              en: "Toolkit",
              pt: "Kit de Ferramentas"
            })}
          </a>
        </li>
      </ul>
    </div>

   

    {/* Newsletter */}
    <div class="flex flex-col md:col-span-1">
      <span class="text-sm font-medium text-foreground uppercase tracking-wider mb-4">
        Newsletter
      </span>
      <p class="text-sm text-gray-600 dark:text-gray-300 mb-4"> 
        {t({
          es: "Mantente actualizado con las últimas novedades",
          en: "Stay updated with the latest news",
          pt: "Mantenha-se atualizado com as últimas novidades"
        })}
      </p>
      <div class="flex flex-col sm:flex-row gap-2">
        <input
          type="email"
          placeholder={t({
            es: "Tu correo electrónico",
            en: "Your email",
            pt: "Seu email"
          })}
          class="px-2 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-md focus:ring-2 focus:ring-maincolor"
          aria-label={t({
            es: "Ingresa tu correo electrónico",
            en: "Enter your email",
            pt: "Digite seu email"
          })}
        />
        <button
          type="submit"
          class="px-4 py-2 bg-maincolor text-white rounded-md hover:bg-maincolor/90 transition-colors"
        >
          {t({
            es: "Suscribirse",
            en: "Subscribe",
            pt: "Inscrever-se"
          })}
        </button>
      </div>
    </div>
  </div>

  {/* Sección inferior */}
  <div class="border-t border-border1 dark:border-gray2 py-4">
    <div class="container flex flex-col sm:flex-row items-center justify-between max-w-[1280px] gap-4">
      <p class="text-sm text-gray-600 dark:text-gray-300">
        <span>© {new Date().getFullYear()} DeSci LATAM · </span>
        <a
          href="https://t.me/descilatam"
          target="_blank"
          rel="noreferrer"
          class="font-medium text-maincolor hover:underline underline-offset-4 transition-colors"
        >
          {t({ es: "Únete a la comunidad", en: "Join the community", pt: "Junte-se à comunidade" })}
        </a>
      </p>

      <div class="flex items-center gap-4">
        <a
          href={siteConfig.links.github}
          target="_blank"
          rel="noreferrer"
          aria-label="GitHub"
          class="text-gray-400 hover:text-maincolor transition-colors"
        >
          <Icon name="github" class="size-5" />
        </a>
        <ThemeToggle client:load />
      </div>
    </div>
  </div>
</footer>