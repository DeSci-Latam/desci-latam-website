            <!-- Top-right quadrant -->
            <path class="logo-q" style="--qi:2" d="M29.7458 8.80386V28.3333H47.4549C52.3314 28.3107 56.2808 24.3708 56.2808 19.5408V0H38.5717C33.7238 0.0283447 29.7458 3.96825 29.7458 8.79819V8.80386Z"/>
            <!-- Bottom-right quadrant -->
            <path class="logo-q" style="--qi:3" d="M29.7458 44.2404C29.7458 47.4094 32.3387 49.9717 35.5096 50.0001H47.1229V37.245C47.1229 34.1044 44.5358 31.5137 41.3649 31.5137H29.7458V44.2404Z"/>
          </svg>
        </div>

        <!-- Floating card — Bangkok -->
        <div
          class="absolute top-8 right-4 lg:right-0 rounded-xl px-4 py-3 text-white text-xs shadow-xl"
          style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(12px);"
        >
          <p class="font-bold text-sm">🌏 Bangkok 2024</p>
          <p class="text-gray-400 mt-0.5">Devcon SEA · 12,500 asistentes</p>
        </div>

        <!-- Floating card — Buenos Aires -->
        <div
          class="absolute bottom-12 left-0 lg:-left-4 rounded-xl px-4 py-3 text-white text-xs shadow-xl"
          style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(12px);"
