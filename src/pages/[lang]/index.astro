<style>
  /* ── Hero logo gradient fix (override global CSS fill) ── */
  #hero-logo-svg path {
    fill: url(#heroLogoGradient) !important;
  }

  /* ── Hero logo animations ─────────────────────────────── */

  /* 1. Continuous float: up/down with a hint of rotation */
  #hero-logo-wrap {
    animation: hero-float 5s ease-in-out infinite;
    transform-origin: center center;
  }
  @keyframes hero-float {
    0%   { transform: translateY(0px)   rotate(0deg); }
    25%  { transform: translateY(-10px) rotate(1.2deg); }
    50%  { transform: translateY(-14px) rotate(0deg); }
    75%  { transform: translateY(-8px)  rotate(-1deg); }
    100% { transform: translateY(0px)   rotate(0deg); }
  }

  /* 2. Hover: scale up + drop-shadow glow */
  #hero-logo-wrap:hover {
    animation-play-state: paused;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
                filter 0.35s ease;
    transform: translateY(-6px) scale(1.08) !important;
    filter: drop-shadow(0 0 28px rgba(155, 90, 255, 0.7))
            drop-shadow(0 0 60px rgba(224, 64, 251, 0.4));
  }

  /* 3. Entry stagger for each quadrant (runs once on load) */
  .logo-q {
    animation:
      logo-q-in 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) both,
      logo-q-breathe 4s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center center;
    animation-delay: calc(var(--qi) * 0.12s), calc(0.7s + var(--qi) * 0.3s);
  }

  @keyframes logo-q-in {
    from {
      opacity: 0;
      transform: scale(0.3) rotate(calc(var(--qi) * 15deg - 22deg));
    }
    to {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
  }

  /* 4. Subtle breathing/scale on each quadrant (slightly offset per piece) */
  @keyframes logo-q-breathe {
    0%, 100% { transform: scale(1); }
    50%       { transform: scale(1.04); }
  }

  /* 5. Glow orb pulse (synced with float) */
  #hero-glow-orb {
    opacity: 0.2;
    animation: glow-orb-pulse 5s ease-in-out infinite;
  }
  @keyframes glow-orb-pulse {
    0%, 100% { transform: scale(1);    opacity: 0.18; }
    50%       { transform: scale(1.35); opacity: 0.32; }
  }

  /* 6. Floating cards subtle entrance */
  #hero-logo-wrap ~ div {
    animation: card-in 0.8s ease both;
  }
  @keyframes card-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>