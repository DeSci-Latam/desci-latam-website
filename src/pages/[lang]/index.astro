<!-- Info sections — "Qué hacemos" -->
<div class="w-screen" style="background: linear-gradient(180deg, #04040c 0%, #080320 50%, #04040c 100%); border-top: 1px solid rgba(99,66,210,0.15);">
  <div class="max-w-screen-xl mx-auto">
    {infos.map((info, i) => (
      <InfoLanding data={info} reverse={i % 2 !== 0} />
