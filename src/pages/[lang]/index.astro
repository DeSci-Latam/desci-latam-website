            <defs>
              <linearGradient id="heroLogoGradient" x1="0%" y1="0%" x2="100%" y2="100%" gradientUnits="objectBoundingBox">
                <!-- Gradient stop colors animate between purple and cyan -->
                <stop offset="0%" stop-color="#9b5aff">
                  <animate attributeName="stop-color"
                    values="#9b5aff; #e040fb; #22d3ee; #9b5aff"
                    dur="6s" repeatCount="indefinite" />
                </stop>
                <stop offset="100%" stop-color="#e040fb">
                  <animate attributeName="stop-color"
                    values="#e040fb; #22d3ee; #9b5aff; #e040fb"
                    dur="6s" repeatCount="indefinite" />
                </stop>
              </linearGradient>
            </defs>
            <!-- Top-left quadrant -->
            <path class="logo-q" style="--qi:0" d="M26.5349 8.80386V28.3333H8.8259C3.94933 28.3107 0 24.3764 0 19.5408V0H17.7033C22.557 0.0340136 26.5349 3.97392 26.5349 8.80386Z"/>
            <!-- Bottom-left quadrant -->
