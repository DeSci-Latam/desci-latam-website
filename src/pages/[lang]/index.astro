---

<Layout>
  <!--   {
    locale === "es" ? (
      <Image src={heroImageEs} alt="こんにちは" />
    ) : locale === "pt" ? (
      <Image src={heroImageptBR} alt="你好" />
    )   :  (
      <Image src={heroImageEn} alt="Hello" />
    )
  } -->

  <!-- ─── HERO ──────────────────────────────────────────────── -->
  <section
    class="bg-animation w-screen min-h-screen flex items-center justify-center px-4 xl:px-0 pt-20 pb-16"
    style="background-color: #04040c;"
  >
    <div class="max-w-screen-xl xl:w-[1280px] w-full grid md:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- LEFT: Copy -->
      <div class="grid gap-7">

        <!-- Tag pill -->
        <div class="flex">
          <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full border border-purple-500/30 text-purple-300">
            🌎 {t({ es: "Science & Technology Hub · LATAM", en: "Science & Technology Hub · LATAM", pt: "Science & Technology Hub · LATAM" })}
          </span>
        </div>

        <!-- H1 -->
        <h1 class="font-heading font-bold text-5xl lg:text-6xl !leading-[1.1] text-white text-balance">
          {t({ es: "El hub de", en: "The hub of", pt: "O hub de" })}{" "}
          <span style="background: linear-gradient(90deg, #9b5aff 0%, #e040fb 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
            {t({ es: "Science & Technology", en: "Science & Technology", pt: "Science & Technology" })}
          </span>{" "}
          {t({ es: "de LATAM", en: "in LATAM", pt: "da LATAM" })}
        </h1>

        <!-- Tagline -->
        <p class="text-lg text-gray-300 text-balance max-w-lg leading-relaxed font-medium">
          {t({
            es: "Conectando la investigación científica con los nuevos modelos de financiamiento y colaboración global.",
            en: "Connecting scientific research with new models of funding and global collaboration.",
            pt: "Conectando a pesquisa científica com os novos modelos de financiamento e colaboração global.",
          })}
        </p>

        <!-- Body -->
        <p class="text-sm text-gray-500 text-balance max-w-lg leading-relaxed">
          {t({
            es: "Científicos, médicos, tecnólogos y builders que buscan reescribir las reglas de la investigación. Desde Buenos Aires a Bangkok — construyendo puentes entre la academia y el ecosistema global.",
            en: "Scientists, doctors, technologists and builders rewriting the rules of research. From Buenos Aires to Bangkok — bridging academia and the global ecosystem.",
            pt: "Cientistas, médicos, tecnólogos e builders reescrevendo as regras da pesquisa. De Buenos Aires a Bangkok — construindo pontes entre a academia e o ecossistema global.",
          })}
        </p>

        <!-- Stats row -->
        <div class="flex flex-wrap gap-6 py-1">
          <div>
            <p class="text-3xl font-bold text-white">3+</p>
            <p class="text-xs text-gray-500 uppercase tracking-widest mt-0.5">{t({ es: "Años", en: "Years", pt: "Anos" })}</p>
          </div>
          <div class="w-px bg-white/10 self-stretch"></div>
          <div>
            <p class="text-3xl font-bold text-white">12.5k+</p>
            <p class="text-xs text-gray-500 uppercase tracking-widest mt-0.5">{t({ es: "Asistentes", en: "Attendees", pt: "Participantes" })}</p>
          </div>
          <div class="w-px bg-white/10 self-stretch"></div>
          <div>
            <p class="text-3xl font-bold text-white">10+</p>
            <p class="text-xs text-gray-500 uppercase tracking-widest mt-0.5">{t({ es: "Eventos", en: "Events", pt: "Eventos" })}</p>
          </div>
          <div class="w-px bg-white/10 self-stretch"></div>
          <div>
            <p class="text-3xl font-bold text-white">NEAR</p>
            <p class="text-xs text-gray-500 uppercase tracking-widest mt-0.5">{t({ es: "Validator", en: "Validator", pt: "Validator" })}</p>
          </div>
        </div>

        <!-- Partners chips -->
        <div class="flex flex-wrap gap-2">
          <span class="text-xs px-3 py-1 rounded-full text-gray-400" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);">
            ⬡ MetaPool · NEAR Validator
          </span>
          <span class="text-xs px-3 py-1 rounded-full text-gray-400" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);">
            ◈ Octant Epoch 4+
          </span>
          <span class="text-xs px-3 py-1 rounded-full text-gray-400" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);">
            ⬡ DeSciWorld
          </span>
          <span class="text-xs px-3 py-1 rounded-full text-gray-400" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);">
            ◈ Ethereum Foundation
          </span>
        </div>

        <!-- Newsletter -->
        <div class="grid gap-2">
          <p class="text-sm text-gray-500">
            {t({ es: "Recibí las últimas novedades en ciencia y tecnología de LATAM", en: "Get the latest science & technology news from LATAM", pt: "Receba as últimas novidades em ciência e tecnologia da LATAM" })}
          </p>
          <form
            class="ml-block-form flex gap-2 max-w-sm"
            action="https://assets.mailerlite.com/jsonp/1150335/forms/135668232739620393/subscribe"
            data-code=""
            method="post"
            target="_blank"
          >
            <input
              type="email"
              name="fields[email]"
              placeholder={t({ es: "tu@email.com", en: "you@email.com", pt: "você@email.com" })}
              autocomplete="email"
              class="flex-1 min-w-0 px-4 py-2.5 rounded-lg text-white text-sm placeholder-gray-600 focus:outline-none focus:ring-1 focus:ring-purple-500"
              style="background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12);"
            />
            <button
              type="submit"
              class="px-5 py-2.5 rounded-lg text-white text-sm font-semibold hover:opacity-90 active:scale-95 transition-all whitespace-nowrap"
              style="background: linear-gradient(90deg, #6342d2 0%, #e040fb 100%);"
            >
              {t({ es: "Suscribirte", en: "Subscribe", pt: "Inscrever-se" })}
            </button>
            <input type="hidden" name="ml-submit" value="1" />
            <input type="hidden" name="anticsrf" value="true" />
          </form>
        </div>

        <!-- CTA buttons -->
        <div class="flex flex-wrap gap-3">
          <a
            href="https://t.me/descilatam"
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-3 rounded-lg text-white text-sm font-semibold transition-all hover:scale-105"
            style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);"
          >
            {t({ es: "Únete a la comunidad", en: "Join the community", pt: "Junte-se à comunidade" })} →
          </a>
          <a
            href="#eventos"
            class="px-6 py-3 rounded-lg text-purple-300 text-sm font-semibold hover:text-white transition-colors"
          >
            {t({ es: "Ver eventos", en: "See events", pt: "Ver eventos" })} ↓
          </a>
        </div>

      </div>

