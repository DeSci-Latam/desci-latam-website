  </div>
</div>

<EventsSection />

</Layout>

<script>
  import { animate } from "motion";
  const showAnimations =
    localStorage.getItem("animations") === "true";

  if (showAnimations) {
    animate(
      ".title",
      { y: [80, 0], opacity: [0, 1] },
      {
        duration: 2.5,
        opacity: { duration: 3 },

        offset: [0, 0.55, 0.75],
      }
    );
  }
</script>

